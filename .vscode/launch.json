{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "request": "launch",
      "name": "TarantulApp Backend (application-local.properties)",
      "cwd": "${workspaceFolder}/backend",
      "mainClass": "com.tarantulapp.TarantulAppApplication",
      "projectName": "tarantulapp-backend"
    },
    {
      "type": "java",
      "request": "launch",
      "name": "TarantulApp Backend (database.local.env)",
      "cwd": "${workspaceFolder}/backend",
      "mainClass": "com.tarantulapp.TarantulAppApplication",
      "projectName": "tarantulapp-backend",
      "envFile": "${workspaceFolder}/backend/database.local.env"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Launch Chrome against localhost",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend"
    }
  ]
}
