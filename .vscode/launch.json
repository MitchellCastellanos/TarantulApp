{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "request": "launch",
      "name": "TarantulApp Backend (local)",
      "cwd": "${workspaceFolder}/backend",
      "mainClass": "com.tarantulapp.TarantulAppApplication",
      "projectName": "tarantulapp-backend",
      "vmArgs": "-Dspring.profiles.active=local"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Launch Chrome against localhost",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend"
    }
  ]
}
