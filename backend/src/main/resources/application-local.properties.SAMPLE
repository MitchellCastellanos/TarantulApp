# Copia este archivo a:
#   backend/src/main/resources/application-local.properties
# (está en .gitignore; no subas contraseñas a git).
#
# Misma información que en producción: solo spring.datasource.* equivalentes a DB_URL / DB_USERNAME / DB_PASSWORD.
# Otra forma local equivalente: backend/database.local.env + VS Code launch "… (database.local.env)".

spring.profiles.active=local
app.dev-seed-user=true

# Conexión directa (recomendado local / Flyway): Supabase → Connect → Direct.
# Host db.<TU_REFERENCE_ID>.supabase.co:5432, usuario postgres, password = Database password.
spring.datasource.url=jdbc:postgresql://db.TU_REFERENCE_ID.supabase.co:5432/postgres?sslmode=require&gssEncMode=disable&connectTimeout=20
spring.datasource.username=postgres
spring.datasource.password=TU_DATABASE_PASSWORD_SUPABASE

# NO pongas maximum-pool-size=1: tras "Successfully validated" Flyway necesita otra conexión para migrate;
# con un solo slot suele quedarse "Connection is not available… 120s" en bucle. Usa 2 o 3 (o borra estas líneas y deja el default del repo).
spring.datasource.hikari.maximum-pool-size=2
spring.datasource.hikari.minimum-idle=0

# Normalmente no hace falta en local, pero si quieres separar migraciones:
# spring.flyway.url=${spring.datasource.url}
# spring.flyway.user=${spring.datasource.username}
# spring.flyway.password=${spring.datasource.password}

# Transaction pooler :6543 solo si lo necesitas; añade a la URL: &prepareThreshold=0

# Usuario seed (LocalDevUserSeed): dev@tarantulapp.local / LocalDev123!
