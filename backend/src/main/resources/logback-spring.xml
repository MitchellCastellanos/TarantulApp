<?xml version="1.0" encoding="UTF-8"?>
<!--
    Switches log format based on app.log-format (defaults to "text").
    Set LOG_FORMAT=json in production so log aggregators (Better Stack, Loki, Papertrail)
    can index fields directly. MDC fields (request_id, user_id, method, path) are emitted
    as first-class JSON keys.

    Sentry events are captured by sentry-spring-boot-starter-jakarta.
    We avoid a dedicated Sentry logback appender to prevent startup warnings when DSN is empty.
-->
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <springProperty scope="context" name="LOG_FORMAT" source="app.log-format" defaultValue="text"/>
    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="tarantulapp-backend"/>

    <if condition='property("LOG_FORMAT").equalsIgnoreCase("json")'>
        <then>
            <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
                <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
                    <providers>
                        <timestamp>
                            <fieldName>timestamp</fieldName>
                            <timeZone>UTC</timeZone>
                        </timestamp>
                        <logLevel>
                            <fieldName>level</fieldName>
                        </logLevel>
                        <loggerName>
                            <fieldName>logger</fieldName>
                            <shortenedLoggerNameLength>40</shortenedLoggerNameLength>
                        </loggerName>
                        <threadName>
                            <fieldName>thread</fieldName>
                        </threadName>
                        <message>
                            <fieldName>message</fieldName>
                        </message>
                        <mdc/>
                        <stackTrace>
                            <fieldName>stack_trace</fieldName>
                            <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                                <maxDepthPerThrowable>30</maxDepthPerThrowable>
                                <maxLength>4096</maxLength>
                                <rootCauseFirst>true</rootCauseFirst>
                            </throwableConverter>
                        </stackTrace>
                        <pattern>
                            <pattern>
                                {
                                  "app": "${APP_NAME}"
                                }
                            </pattern>
                        </pattern>
                    </providers>
                </encoder>
            </appender>
            <root level="INFO">
                <appender-ref ref="JSON"/>
            </root>
        </then>
        <else>
            <appender name="TEXT" class="ch.qos.logback.core.ConsoleAppender">
                <encoder>
                    <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] [req=%X{request_id:-}] %logger{36} - %msg%n</pattern>
                </encoder>
            </appender>
            <root level="INFO">
                <appender-ref ref="TEXT"/>
            </root>
        </else>
    </if>
</configuration>
