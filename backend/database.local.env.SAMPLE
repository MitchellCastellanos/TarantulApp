# Copia a backend/database.local.env (gitignored vía *.env).
# VS Code → Run "TarantulApp Backend (database.local.env)".
#
# Mismas tres variables que en Railway: DB_URL, DB_USERNAME, DB_PASSWORD.
# Session pooler (5432) + usuario postgres.<ref> — ver Supabase Dashboard → Connect.

SPRING_PROFILES_ACTIVE=local
