# URL canónica del frontend (https://…, sin barra final). Opcional: por defecto el build usa https://tarantulapp.com
# (sitemap.xml, robots.txt y middleware de dev/preview). Define esta variable solo para staging u otro dominio.
# VITE_PUBLIC_SITE_URL=https://staging.ejemplo.com

# Build / preview del frontend contra tu API en producción (sin proxy de Vite).
# En desarrollo, `.env.development` deja VITE_API_URL vacío para usar el proxy de Vite (recomendado).
VITE_API_URL=

# Opcional: versión mostrada en Cuenta / Acerca
VITE_APP_VERSION=0.1.0

# Opcional: correo de soporte (mailto) en Cuenta; si no se define, se usa support@tarantulapp.com
VITE_SUPPORT_EMAIL=

# Opcional: Google OAuth Client ID (Google Identity Services, login social en /login)
VITE_GOOGLE_CLIENT_ID=

# Opcional (solo dev / sin redeploy del API): CSV de emails para mostrar /admin en el build.
# En producción el backend envía admin: true en login y GET /api/billing/me usando APP_ADMIN_EMAILS en el servicio Java.
VITE_ADMIN_EMAILS=
